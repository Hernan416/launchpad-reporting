# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Base64-encoded JSON array of app users. Steps:
#   1. Copy users.example.json to users.local.json (gitignored) and fill it in.
#      Generate each passwordHash with: npm run hash-password -- "the-users-password"
#   2. Run: npm run build-app-users
#   3. Paste the printed base64 string here.
# role "master" sees every client; role "client" is restricted to its own clientSlug
# (clientSlug must match a slug in config/clients.ts).
#
# Base64 (not raw JSON) is used because bcrypt hashes contain `$` characters
# that Next.js's .env loader treats as variable interpolation, silently
# corrupting the hash if stored as plain text.
APP_USERS_BASE64=

# --- Meta Ads ---
# Long-lived System User access token (ads_read) on the Business Manager
# that owns every client's ad account.
META_ACCESS_TOKEN=

# --- GoHighLevel ---
# GHL API v1's shared agency key is end-of-life; v2 has no equivalent
# (an agency OAuth token can't read sub-account data directly, and its
# location-token exchange needs OAuth refresh handling we can't do without
# a database). Instead: one static Private Integration Token per client,
# generated from that client's GHL sub-account under Settings > Private
# Integrations. Env var name is GHL_TOKEN_<SLUG_UPPER_SNAKE>, matching the
# slug in config/clients.ts (e.g. "excel-roofing" -> GHL_TOKEN_EXCEL_ROOFING).
GHL_TOKEN_EXCEL_ROOFING=
GHL_TOKEN_ONE_DAY_ROOFING=
GHL_TOKEN_US_HOME_PRO=
